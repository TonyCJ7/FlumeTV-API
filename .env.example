# FlumeTV API
#
# Copy to .env. Shown values match code defaults where set.
# Details: README.md → Environment variables


# Required — server will not start without these
SESSION_JWT_SECRET=change_this_to_a_long_random_secret_for_sessions
ADDON_SECRET_KEY=change_this_to_a_long_random_secret_for_addon_tokens
# Host-only (npm run dev:local / start:local). npm run dev and npm run start override this in Compose (@postgres:5432).
DATABASE_URL=postgresql://flumetv:flumetv@localhost:5432/flumetv

# Pool size caps (omit for defaults: HTTP pool max 10, worker pool max 2)
PG_POOL_MAX=
PG_POOL_MAX_WORKER=

# Compose-only: published host port when using docker-compose `postgres` service (default 5432)
POSTGRES_PORT=


# Stremio addon
ID_PREFIX=flumetv_


# Server
PORT=7001
FRONTEND_ORIGIN=http://localhost:7000
BASE_URL=
TRUST_PROXY=
NODE_ENV=


# Session cookie
SESSION_COOKIE_NAME=session
SESSION_MAX_AGE_SECONDS=604800


# Auth rate limit
AUTH_RATE_LIMIT_MAX=60
AUTH_RATE_LIMIT_WINDOW_MS=900000


# Logging
DEBUG_MODE=true


# Prefetch queue and scheduler
FETCH_PARALLELISM=4
FETCH_MAX_BACKLOG_HOURS=20
SCHEDULER_DUE_POLL_MS=30000
DEFAULT_SCHEDULER_INTERVAL_MINUTES=1440
FETCH_TIMING_MAX_ROWS=500
DEFAULT_FETCH_DURATION_MS_ESTIMATE=120000


# Upstream fetch timeouts (ms)
XTREAM_CATALOG_FETCH_TIMEOUT_MS=3600000
XTREAM_META_FETCH_TIMEOUT_MS=120000
DIRECT_M3U_FETCH_TIMEOUT_MS=3600000


# Outbound HTTP proxy
HTTP_PROXY=
HTTPS_PROXY=


# MediaFlow stream proxy (optional)
# MEDIAFLOW_PROXY_URL — Python mediaflow-proxy or Rust MediaFlow Proxy Light base URL
# MEDIAFLOW_PROXY_API_PASSWORD — MediaFlow API password
# MEDIAFLOW_PROXY_PUBLIC_URL — public HTTPS origin when API reaches MediaFlow on internal URL
# When both URL + password are set: http/https playback URLs rewritten through MediaFlow
# MEDIAFLOW_PROXY_TRANSCODE — set to 1, true, or yes to add transcode=true on generate_urls (CPU/GPU load on proxy host)
# MEDIAFLOW_PROXY_RESOLVE_REDIRECTS — set to 1, true, or yes to resolve panel 302 CDN URLs before MediaFlow (also on when transcode is enabled)
# When unset: addon streams get behaviorHints.notWebReady (external player recommended)
MEDIAFLOW_PROXY_URL=
MEDIAFLOW_PROXY_API_PASSWORD=
MEDIAFLOW_PROXY_PUBLIC_URL=
MEDIAFLOW_PROXY_TRANSCODE=
MEDIAFLOW_PROXY_RESOLVE_REDIRECTS=


# Room logs and sync progress
SYNC_PROGRESS_MIN_INTERVAL_MS=500
LOG_SECTOR_PROGRESS_MIN_INTERVAL_MS=


# Prefetch worker children
PREFETCH_WORKER_NODE_OPTIONS=
PREFETCH_WORKER_SCRIPT=


# Internal — do not set on the HTTP process (worker child sets this)

# PREFETCH_SYNC_WORKER=1
