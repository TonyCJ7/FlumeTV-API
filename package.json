{
  "name": "flumetv-api",
  "version": "1.0.0",
  "license": "CC-BY-NC-4.0",
  "description": "FlumeTV API — PostgreSQL-backed Stremio IPTV backend with M3U/EPG ingestion, Xtream Codes, encrypted addon tokens, prefetch workers, scheduler/queue, SSE for sync progress and logs, and REST for the FlumeTV UI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TonyCJ7/FlumeTV-API.git"
  },
  "homepage": "https://github.com/TonyCJ7/FlumeTV-API#readme",
  "bugs": {
    "url": "https://github.com/TonyCJ7/FlumeTV-API/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "docker compose up --build",
    "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "start:local": "NODE_ENV=production node dist/index.js",
    "dev:local": "tsx watch src/index.ts",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "db:migrate": "tsx src/scripts/runMigrations.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "axios": "^1.15.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.2",
    "global-agent": "^3.0.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "pg": "^8.21.0",
    "stremio-addon-sdk": "^1.6.10",
    "xml2js": "^0.4.23"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^4.4.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "@types/stremio-addon-sdk": "^1.6.12",
    "@types/xml2js": "^0.4.14",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-sql": "^3.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-embed": "^0.5.1",
    "prettier-plugin-sql": "^0.20.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.2"
  },
  "lint-staged": {
    "*.{ts,tsx, mjs, cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ]
  }
}
